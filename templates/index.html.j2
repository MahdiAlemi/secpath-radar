<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ brief.site_title }} — {{ brief.date_en }}</title>
  <link rel="icon" type="image/svg+xml" href="assets/favicon.svg" />
  <link rel="stylesheet" href="assets/css/radar.css" />
  <link rel="alternate" type="application/rss+xml" title="SecPath Radar RSS" href="feed.xml" />
  <link rel="alternate" type="application/json" title="SecPath Radar JSON API" href="api/summary.json" />
  <script src="assets/js/radar.js" defer></script>
</head>
<body>
{% macro riskcls(score) %}{{ "high" if score >= 8 else ("medium" if score >= 5 else "low") }}{% endmacro %}
{% macro bars(rows, limit) %}
<div class="bars">
  {% for r in rows %}{% if loop.index <= limit %}
  <div class="bar-row"><span class="bar-label">{{ r.name }}</span><span class="bar-track"><b style="width: {{ r.bar_width }}%"></b></span><span class="bar-count">{{ r.count }}</span></div>
  {% endif %}{% endfor %}
</div>
{% endmacro %}
{% macro news_card(item) %}
<article class="item risk-{{ riskcls(item.risk_score) }}{% if item.is_today == false %} is-older{% endif %}">
  <div class="item-head">
    <h3><a href="{{ item.url }}" rel="noopener noreferrer">{{ item.title }}</a></h3>
    <span class="score">{{ item.risk_score }}</span>
  </div>
  <p class="news-excerpt">{{ item.summary }}</p>
  <div class="meta">
    <span class="news-source">{{ item.source }}</span>
    <span class="news-time">{{ item.published_time_local }} Tehran &middot; {{ item.published_time_utc }}</span>
    <span class="news-date">{{ item.published_date_local }}</span>
    {% if item.is_new %}<span class="tag tag-new">New</span>{% endif %}
    {% for tag in item.tags %}{% if loop.index <= 2 %}<span class="tag">{{ tag }}</span>{% endif %}{% endfor %}
  </div>
</article>
{% endmacro %}
{% macro breaking_card(item) %}
<article class="item risk-{{ riskcls(item.risk_score) }}">
  <div class="item-head">
    <a href="{{ item.url }}" rel="noopener noreferrer" target="_blank">{{ item.title }}</a>
  </div>
  {% if item.summary %}<p class="news-excerpt">{{ item.summary }}</p>{% endif %}
  <div class="meta">
    <span class="breaking-source">{{ item.source }}</span>
    {% for tag in item.tags %}{% if loop.index <= 3 %}<span class="tag">{{ tag }}</span>{% endif %}{% endfor %}
  </div>
  <div class="meta">
    <span>{{ item.published_time_local }} Tehran · {{ item.published_time_utc }} · {{ item.published_date_local }}</span>
  </div>
</article>
{% endmacro %}

{% macro news_stream_card(item) %}
<article class="news-top-card">
  <div class="news-top-main">
    <div class="news-top-titleline">
      <a href="{{ item.url }}" rel="noopener noreferrer" target="_blank">{{ item.title }}</a>
      {% if item.is_new %}<span class="tag tag-new">New</span>{% endif %}
    </div>
    {% if item.summary %}<p class="news-excerpt">{{ item.summary }}</p>{% endif %}
    <div class="meta news-top-source-line">
      <span class="news-source">{{ item.source }}</span>
      {% for tag in item.tags %}{% if loop.index <= 2 %}<span class="tag">{{ tag }}</span>{% endif %}{% endfor %}
    </div>
    <div class="meta news-top-time-line">
      <span>{{ item.published_time_local }} Tehran · {{ item.published_time_utc }} · {{ item.published_date_local }}</span>
    </div>
  </div>
</article>
{% endmacro %}

<header class="topbar topbar-redesign">
  <div class="brand brand-redesign">
    <img class="brand-logo" src="assets/logo.svg" alt="" width="34" height="34" />
    <div class="brand-copy"><strong>SecPath Radar</strong><span class="brand-sub">Passive Cyber Threat Monitoring</span></div>
  </div>
  <div class="topbar-status">
    <span class="live-chip" id="today-chip" data-today="{{ brief.date_en }}"><i class="live-dot"></i><span>Today &middot; {{ brief.date_en }}</span></span>
  </div>
  <div class="topbar-actions">
    {% if brief.site_github %}
    <a class="ui-chip icon-chip" href="{{ brief.site_github }}" rel="noopener noreferrer" target="_blank" aria-label="Open GitHub repository">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .9a11.1 11.1 0 0 0-3.5 21.6c.55.1.75-.24.75-.53v-2.1c-3.05.67-3.7-1.3-3.7-1.3-.5-1.25-1.22-1.58-1.22-1.58-1-.68.08-.67.08-.67 1.1.08 1.68 1.14 1.68 1.14.98 1.67 2.57 1.19 3.2.91.1-.71.38-1.19.69-1.46-2.43-.28-4.99-1.22-4.99-5.43 0-1.2.43-2.18 1.13-2.95-.11-.28-.49-1.4.11-2.91 0 0 .92-.3 3.02 1.13A10.3 10.3 0 0 1 12 6.38c.94 0 1.88.13 2.76.37 2.1-1.43 3.02-1.13 3.02-1.13.6 1.51.22 2.63.11 2.91.7.77 1.13 1.75 1.13 2.95 0 4.22-2.57 5.15-5.02 5.42.4.35.75 1.02.75 2.06v3.01c0 .29.2.64.76.53A11.1 11.1 0 0 0 12 .9Z"/></svg>
      <span>GitHub</span>
    </a>
    {% endif %}
    <a class="ui-chip icon-chip feed-chip" href="feed.xml" rel="noopener noreferrer" aria-label="Open RSS XML feed">
      <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M5.1 17.7a2.2 2.2 0 1 1 0 4.4 2.2 2.2 0 0 1 0-4.4Zm-2-7.25c6.4 0 11.6 5.2 11.6 11.6h-3.15a8.45 8.45 0 0 0-8.45-8.45v-3.15Zm0-7.1c10.32 0 18.7 8.38 18.7 18.7h-3.2c0-8.55-6.95-15.5-15.5-15.5v-3.2Z"/></svg>
      <span>RSS XML</span>
    </a>
    <a class="ui-chip icon-chip api-chip" href="api/summary.json" rel="noopener noreferrer" aria-label="Open JSON summary API">
      <span class="json-glyph">{ }</span>
      <span>JSON API</span>
    </a>
  </div>
</header>

<main class="shell">

  <section class="radar-overview" aria-label="One-glance radar overview">
    <div class="overview-card overview-risk risk-{{ brief.risk_level|lower }}"><span>Today Risk</span><b>{{ brief.executive_snapshot.score }}</b><small>{{ brief.risk_level }}</small></div>
    <div class="overview-card"><span>CVEs Today</span><b>{{ brief.stats.cves }}</b><small>{{ brief.stats.critical_cves }} Critical · {{ brief.stats.kev }} KEV</small></div>
    <div class="overview-card"><span>Exploit Watch</span><b>{{ brief.stats.poc_watch }}</b><small>PoC repos · {{ brief.stats.epss_rising }} EPSS↑</small></div>
    <div class="overview-card"><span>News / Writeups</span><b>{{ brief.stats.daily_news }}</b><small>{{ brief.stats.breaking_news }} Breaking · {{ brief.stats.writeups }} Writeups</small></div>
    <div class="overview-card"><span>Threat Telemetry</span><b>{{ brief.stats.iocs }}</b><small>{{ brief.stats.botnet_c2 }} C2 · {{ brief.stats.phishing_urls }} Phishing</small></div>
    <div class="overview-card"><span>Templates</span><b>{{ brief.stats.nuclei_coverage_pct }}%</b><small>{{ brief.stats.nuclei_covered_cves }} CVE covered</small></div>
  </section>

  <section class="top-layout top-layout-columns top-layout-balanced" aria-label="Balanced dashboard intelligence columns">
    <div class="top-column top-column-breaking" aria-label="Breaking, coverage, and advisory context">
    <section id="breaking-news" class="panel panel-breaking panel-breaking-col panel-column-fill">
      <div class="panel-head"><div><span class="eyebrow">BREAKING</span><h2>Breaking News</h2></div><span class="chip chip-risk">{{ brief.breaking_news|length }}</span></div>
      {% if brief.breaking_news %}
      <div class="breaking-scroll">
        {% for item in brief.breaking_news %}{{ breaking_card(item) }}{% endfor %}
      </div>
      {% else %}
      <p class="empty-note">No breaking news recorded in today's window.</p>
      {% endif %}
    </section>

      <section id="nuclei-coverage" class="panel panel-intel-card panel-nuclei-card risk-{{ brief.nuclei_coverage.risk }}">
        <div class="panel-head">
          <div><span class="eyebrow">Nuclei Coverage</span><h2>Template Coverage</h2></div>
          <div class="panel-head-actions">
            <span class="chip">{{ brief.nuclei_coverage.totals.coverage_pct }}%</span>
            <span class="chip chip-muted">{{ brief.nuclei_coverage.level }}</span>
          </div>
        </div>
        <div class="intel-metric-row">
          <div><b>{{ brief.nuclei_coverage.totals.covered_cves }}</b><span>covered CVE</span></div>
          <div><b>{{ brief.nuclei_coverage.totals.missing_cves }}</b><span>missing CVE</span></div>
          <div><b>{{ brief.nuclei_coverage.totals.template_paths }}</b><span>template paths</span></div>
        </div>
        <div class="intel-meter"><b style="width: {{ brief.nuclei_coverage.totals.coverage_pct }}%"></b></div>
        <p class="lede lede-tight">{{ brief.nuclei_coverage.summary }}</p>
        <div class="intel-kv-row">
          <span>Missing critical <b>{{ brief.nuclei_coverage.totals.missing_critical }}</b></span>
          <span>Missing high <b>{{ brief.nuclei_coverage.totals.missing_high }}</b></span>
          <span>Top protocol <b>{{ brief.nuclei_coverage.top_protocol.name }}</b></span>
        </div>
        {% if brief.nuclei_coverage.covered %}
        <div class="intel-list-title">Matched templates</div>
        {% for row in brief.nuclei_coverage.covered %}{% if loop.index <= 4 %}
        <div class="intel-row risk-{{ row.risk }}">
          <div><b>{{ row.cve_id }}</b><span>{{ row.protocol }} · {{ row.template_count }} template</span></div>
          <small>{{ row.template_path_safe }}</small>
        </div>
        {% endif %}{% endfor %}
        {% elif brief.nuclei_coverage.missing %}
        <div class="intel-list-title">Coverage gaps</div>
        {% for row in brief.nuclei_coverage.missing %}{% if loop.index <= 4 %}
        <div class="intel-row risk-{{ row.risk }}">
          <div><b>{{ row.cve_id }}</b><span>{{ row.severity }}</span></div>
          <small>{{ row.title }}</small>
        </div>
        {% endif %}{% endfor %}
        {% endif %}
        <div class="meta"><span>{{ brief.nuclei_coverage.provider }}</span><span>metadata only · no scan</span></div>
      </section>

      {% if brief.csaf_pulse.ok %}
      <section id="csaf-pulse" class="panel panel-intel-card panel-csaf-card risk-{{ brief.csaf_pulse.level|lower }}">
        <div class="panel-head">
          <div><span class="eyebrow">CSAF</span><h2>Vendor Advisories</h2></div>
          <div class="panel-head-actions"><span class="chip">{{ brief.csaf_pulse.totals.advisories }} advisory</span><span class="chip chip-muted">CVSS {{ brief.csaf_pulse.totals.max_cvss }}</span></div>
        </div>
        <div class="intel-metric-row intel-metric-row-compact advisory-metric-row">
          <div><b>{{ brief.csaf_pulse.totals.important_plus }}</b><span>Important+</span></div>
          <div><b>{{ brief.csaf_pulse.totals.remediations }}</b><span>Remediation</span></div>
          <div><b>{{ brief.csaf_pulse.totals.products }}</b><span>Products</span></div>
        </div>
        {% if brief.csaf_pulse.spotlight %}
        <div class="advisory-spotlight risk-{{ brief.csaf_pulse.spotlight.risk }}">
          <div><span>Top advisory</span><a href="{{ brief.csaf_pulse.spotlight.url }}" rel="noopener noreferrer" target="_blank">{{ brief.csaf_pulse.spotlight.id }}</a></div>
          <strong>{{ brief.csaf_pulse.spotlight.severity }}</strong>
        </div>
        <p class="lede lede-tight">{{ brief.csaf_pulse.spotlight.title }}</p>
        {% endif %}
        <div class="intel-kv-row threat-kv-row"><span><b>Product</b> {{ brief.csaf_pulse.insights.top_product }}</span><span><b>CVE</b> {{ brief.csaf_pulse.insights.top_cve }}</span><span><b>Fix</b> {{ brief.csaf_pulse.insights.fix_signal }}</span></div>
        <div class="split-bars threat-bars">
          <div><span>Severity</span>{{ bars(brief.csaf_pulse.severity_chart, 3) }}</div>
          <div><span>Products</span>{{ bars(brief.csaf_pulse.product_chart, 3) }}</div>
        </div>
        <div class="meta"><span>{{ brief.csaf_pulse.provider }}</span><span>official CSAF metadata</span></div>
      </section>
      {% endif %}

      {% if brief.supply_chain_radar.ok %}
      <section id="supply-chain-radar" class="panel panel-intel-card panel-supply-card risk-{{ brief.supply_chain_radar.level|lower }}">
        <div class="panel-head">
          <div><span class="eyebrow">Supply Chain</span><h2>Supply Chain Advisories</h2></div>
          <div class="panel-head-actions">
            <span class="chip">{{ brief.supply_chain_radar.totals.advisories }} advisory</span>
            <span class="chip chip-muted">{{ brief.supply_chain_radar.level }}</span>
          </div>
        </div>
        <div class="intel-metric-row">
          <div><b>{{ brief.supply_chain_radar.totals.high }}</b><span>high</span></div>
          <div><b>{{ brief.supply_chain_radar.totals.fixed }}</b><span>fix listed</span></div>
          <div><b>{{ brief.supply_chain_radar.totals.epss_hot }}</b><span>EPSS hot</span></div>
        </div>
        {% if brief.supply_chain_radar.spotlight.title %}
        <article class="supply-spotlight risk-{{ brief.supply_chain_radar.spotlight.risk }}">
          <div class="supply-titleline">
            <a href="{{ brief.supply_chain_radar.spotlight.url }}" rel="noopener noreferrer" target="_blank">{{ brief.supply_chain_radar.spotlight.id }}</a>
            <span class="tag">{{ brief.supply_chain_radar.spotlight.severity }}</span>
          </div>
          <p>{{ brief.supply_chain_radar.spotlight.title }}</p>
          <div class="supply-meta"><span>{{ brief.supply_chain_radar.spotlight.ecosystem }} / {{ brief.supply_chain_radar.spotlight.package }}</span><span>CVSS {{ brief.supply_chain_radar.spotlight.cvss }}</span><span>EPSS {{ brief.supply_chain_radar.spotlight.epss_pct }}%</span></div>
        </article>
        {% endif %}
        <div class="intel-kv-row">
          <span>Top ecosystem <b>{{ brief.supply_chain_radar.top_ecosystem.name }}</b></span>
          <span>Top package <b>{{ brief.supply_chain_radar.top_package.name }}</b></span>
          <span>Unfixed <b>{{ brief.supply_chain_radar.totals.unfixed }}</b></span>
        </div>
        <div class="intel-list-title">Ecosystem mix</div>
        {{ bars(brief.supply_chain_radar.ecosystem_chart, 5) }}
        <div class="meta"><span>{{ brief.supply_chain_radar.provider }}</span><span>GitHub Advisory API + OSV links</span></div>
      </section>
      {% endif %}

      <section id="drop-pulse" class="panel panel-intel-card panel-drop-card risk-{{ brief.drop_pulse.level|lower }}">
        <div class="panel-head">
          <div><span class="eyebrow">DROP</span><h2>Hostile IP Ranges</h2></div>
          <div class="panel-head-actions"><span class="chip">{{ brief.drop_pulse.totals.ranges }} ranges</span><span class="chip chip-muted">{{ brief.drop_pulse.totals.est_ips_millions }}M IPs</span></div>
        </div>
        <div class="intel-metric-row intel-metric-row-compact advisory-metric-row">
          <div><b>{{ brief.drop_pulse.totals.big_ranges }}</b><span>Large ranges</span></div>
          <div><b>{{ brief.drop_pulse.totals.rirs }}</b><span>RIRs</span></div>
          <div><b>{{ brief.drop_pulse.totals.high }}</b><span>High spread</span></div>
        </div>
        {% if brief.drop_pulse.spotlight %}
        <div class="advisory-spotlight drop-spotlight risk-{{ brief.drop_pulse.spotlight.risk }}">
          <div><span>Largest netblock</span><b dir="ltr">{{ brief.drop_pulse.spotlight.cidr_safe }}</b></div>
          <strong>{{ brief.drop_pulse.spotlight.rir }}</strong>
        </div>
        {% endif %}
        <div class="intel-kv-row threat-kv-row"><span><b>Top RIR</b> {{ brief.drop_pulse.insights.top_rir }}</span><span><b>Largest</b> {{ brief.drop_pulse.insights.largest_cidr }}</span><span><b>Route</b> {{ brief.drop_pulse.insights.routing_note }}</span></div>
        <div class="split-bars threat-bars">
          <div><span>RIR mix</span>{{ bars(brief.drop_pulse.rir_chart, 3) }}</div>
          <div><span>Prefix size</span>{{ bars(brief.drop_pulse.prefix_chart, 3) }}</div>
        </div>
        <div class="meta"><span>{{ brief.drop_pulse.provider }}</span><span>defanged · denylist metadata</span></div>
      </section>
      <section id="attack-pressure" class="panel panel-intel-card">
        <div class="panel-head"><div><span class="eyebrow">Attack Pressure</span><h2>Attack Pressure</h2></div><span class="chip">{{ brief.attack_pressure.level }}</span></div>
        <p class="lede">{{ brief.attack_pressure.summary }}</p>
        {% for p in brief.attack_pressure.top_ports %}{% if loop.index <= 8 %}
        <div class="row risk-{{ p.risk }}">
          <div class="row-head"><b>Port {{ p.port }} &middot; {{ p.service }}</b><span>{{ p.description }}</span></div>
          <p class="note">{{ p.note }}</p>
        </div>
        {% endif %}{% endfor %}
        <div class="meta"><span>{{ brief.attack_pressure.provider }}</span></div>
      </section>

      <section id="sources" class="panel panel-intel-card panel-meta-card panel-data-card">
        <div class="panel-head"><div><span class="eyebrow">Data</span><h2>Data Feeds</h2></div></div>
        <p class="note">Automated collection from trusted security feeds, NVD, CISA KEV, EPSS, and public threat telemetry; all read-only with no active scanning.</p>
        <div class="meta">
          <span>{{ brief.source_health.rss_sources }} news feeds</span>
          <span>{{ brief.source_health.intel_sources }} telemetry sources</span>
          {% if brief.source_health.degraded_rss_sources %}
          <span>{{ brief.source_health.failed_rss_sources }} failed · {{ brief.source_health.stale_rss_sources }} stale</span>
          {% endif %}
        </div>
      </section>

    </div>

    <div class="top-column top-column-weekly" aria-label="Weekly and infrastructure telemetry context">
    <section class="panel panel-top-card panel-weekly-right panel-weekly-top weekly-compact">
      <div class="panel-head">
        <div><span class="eyebrow">WEEKLY</span><h2>Week at a Glance</h2></div>
        <span class="chip">{{ brief.weekly.totals.days }}d</span>
      </div>

      <div class="weekly-hero">
        <div class="weekly-total weekly-total-primary"><b>{{ brief.weekly.totals.cves }}</b><span>CVEs</span></div>
        <div class="weekly-total"><b>{{ brief.weekly.totals.news }}</b><span>News</span></div>
        <div class="weekly-total"><b>{{ brief.weekly.totals.kev }}</b><span>KEV</span></div>
      </div>
      <div class="weekly-block weekly-days">
        <div class="weekly-block-title"><span>Daily Breakdown</span></div>
        <div class="weekly-day-strip">
          {% for row in brief.weekly.daily_rows %}
          <div class="weekly-day">
            <b>{{ row.label }}</b>
            <span><strong>{{ row.cves }}</strong> CVE</span>
            <span><strong>{{ row.news }}</strong> News</span>
          </div>
          {% endfor %}
        </div>
      </div>

      <div class="weekly-two-up">
        <div class="weekly-block weekly-today">
          <div class="weekly-block-title"><span>Today</span></div>
          <div class="weekly-pill-row">
            <span><b class="c-red">{{ brief.stats.breaking_news }}</b> Breaking</span>
            <span><b class="c-amber">{{ brief.stats.epss_rising }}</b> EPSS&uarr;</span>
            <span><b>{{ brief.stats.poc_watch }}</b> PoC</span>
          </div>
        </div>

        <div class="weekly-block weekly-snapshot">
          <div class="weekly-block-title"><span>60-Second</span><b>{{ brief.executive_snapshot.score }}/100</b></div>
          <div class="weekly-risk-list">
            {% for card in brief.executive_snapshot.risk_cards %}
            <div class="weekly-risk-row"><span>{{ card.title }}</span><b>{{ card.metric }}</b></div>
            {% endfor %}
          </div>
        </div>
      </div>

      <div class="weekly-block weekly-trend">
        <div class="weekly-block-title"><span>Trend</span><b>{{ brief.trend_pulse.totals.runs }}r</b></div>
        {% if brief.trend_pulse.ok %}
        <div class="weekly-trend-list">
          {% for row in brief.trend_pulse.rows %}
          <div class="weekly-trend-row delta-{{ row.direction }}">
            <span>{{ row.label }}</span>
            <svg viewBox="0 0 60 16" preserveAspectRatio="none"><polyline points="{{ row.spark }}" vector-effect="non-scaling-stroke"/></svg>
            <b>{% if row.delta > 0 %}+{% endif %}{{ row.delta }}</b>
          </div>
          {% endfor %}
        </div>
        {% else %}
        <p class="weekly-summary weekly-summary-muted">{{ brief.trend_pulse.summary }}</p>
        {% endif %}
      </div>
    </section>

      <section id="ioc-radar" class="panel panel-intel-card panel-ioc-radar risk-{{ brief.ioc_radar.level|lower }}">
        <div class="panel-head">
          <div><span class="eyebrow">IOC Radar</span><h2>Active Threats</h2></div>
          <div class="panel-head-actions"><span class="chip">{{ brief.ioc_radar.totals.total }} IOC</span><span class="chip chip-muted">{{ brief.ioc_radar.level }}</span></div>
        </div>
        <div class="intel-metric-row intel-metric-row-compact">
          <div><b>{{ brief.ioc_radar.totals.high }}</b><span>high risk</span></div>
          <div><b>{{ brief.ioc_radar.totals.high_confidence }}</b><span>high confidence</span></div>
          <div><b>{{ brief.ioc_radar.totals.families }}</b><span>families</span></div>
        </div>
        <div class="ioc-insight-strip">
          <span>Top family <b>{{ brief.ioc_radar.insights.top_family }}</b></span>
          <span>Type <b>{{ brief.ioc_radar.insights.top_type }}</b></span>
          <span>Source <b>{{ brief.ioc_radar.insights.top_source }}</b></span>
        </div>
        <div class="intel-list-title">Highest signal indicators</div>
        {% for row in brief.ioc_radar.top_indicators %}{% if loop.index <= 4 %}
        <div class="intel-row ioc-signal-row risk-{{ row.risk }}">
          <div><b dir="ltr">{{ row.indicator_safe }}</b><span>{{ row.risk_score }}/100</span></div>
          <small>{{ row.source }} · {{ row.indicator_type }} · {{ row.malware }} · conf {{ row.confidence }}%</small>
        </div>
        {% endif %}{% endfor %}
        <div class="split-bars">
          <div><span>Malware mix</span>{{ bars(brief.ioc_radar.malware_chart, 3) }}</div>
          <div><span>Indicator types</span>{{ bars(brief.ioc_radar.type_chart, 3) }}</div>
        </div>
        <div class="meta"><span>{{ brief.ioc_radar.provider }}</span><span>defanged · passive</span></div>
      </section>

      {% if brief.greynoise_context.ok %}
      <section id="greynoise-context" class="panel panel-intel-card panel-greynoise-card risk-{{ brief.greynoise_context.level|lower }}">
        <div class="panel-head">
          <div><span class="eyebrow">GreyNoise</span><h2>Scanner Context</h2></div>
