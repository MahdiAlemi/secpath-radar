              <div class="poc-meta">
                <span>{{ repo.age_days }}d old</span>
                <span>★ {{ repo.stars }}</span>
                <span>fork {{ repo.forks }}</span>
                <span>{{ repo.published_date }}</span>
              </div>
            </div>
            <div class="poc-score">
              <strong>{{ repo.score }}</strong>
              <span>signal</span>
            </div>
          </article>
          {% endfor %}
