<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ brief.site_title }} — {{ brief.date_fa }}</title>
  <link rel="icon" type="image/svg+xml" href="assets/favicon.svg" />
  <link rel="stylesheet" href="assets/css/radar.css" />
  <script src="assets/js/radar.js" defer></script>
</head>
<body>
  <main class="shell">
    <nav class="topbar" aria-label="وضعیت تولید">
      <div class="brand"><span class="brand-mark">▦</span><span>SecPath Radar</span></div>
      <div class="topbar-status">
        <span>{{ brief.date_fa }}</span>
        <span>{{ brief.source_health.rss_sources }} RSS</span>
        <span>{{ brief.source_health.intel_sources }} تله‌متری</span>
        <span>نمای تولید</span>
      </div>
    </nav>

    <header class="hero production-hero">
      <div>
        <span class="eyebrow">نمای عملیاتی فشرده</span>
        <h1>داشبورد امنیت سایبری امروز</h1>
        <p>خلاصه تولیدی و سه‌ستونه از خبر، آسیب‌پذیری، فشار حمله، IOC، زیرساخت مشکوک، زنجیره تأمین و باج‌افزار؛ بدون کنترل تعاملی و بدون اطلاعات اضافه غیرضروری.</p>
      </div>
      <div class="hero-score risk-{{ brief.executive_snapshot.level }}">
        <span>امتیاز ریسک</span>
        <strong>{{ brief.executive_snapshot.score }}</strong>
        <small>{{ brief.executive_snapshot.level }}</small>
      </div>
    </header>

    <section class="metric-strip" aria-label="شاخص‌های یک نگاه">
      <div><span>خبرها</span><b>{{ brief.stats.global_news }}</b></div>
      <div><span>ایران</span><b>{{ brief.stats.iran_items }}</b></div>
      <div><span>CVE</span><b>{{ brief.stats.cves }}</b><small>{{ brief.stats.critical_cves }} critical</small></div>
      <div><span>EPSS ↑</span><b>{{ brief.stats.epss_rising }}</b><small>momentum</small></div>
      <div><span>CISA</span><b>{{ brief.stats.vulnrichment_hits }}</b><small>SSVC</small></div>
      <div><span>IOC</span><b>{{ brief.stats.iocs }}</b></div>
      <div><span>زیرساخت</span><b>{{ brief.stats.infrastructure_hosts }}</b></div>
      <div><span>زنجیره تأمین</span><b>{{ brief.stats.supply_chain_advisories }}</b></div>
      <div><span>Ransomware</span><b>{{ brief.stats.ransomware_victims }}</b></div>
      <div><span>RSS خطادار</span><b>{{ brief.stats.failed_rss_sources }}</b></div>
    </section>

    <section class="dashboard-grid" aria-label="چیدمان سه‌ستونه رادار">
      <aside class="column column-risk">
        <section id="executive-snapshot" class="panel executive-panel" aria-label="خلاصه مدیریتی">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">خلاصه مدیریتی</span><h2>خلاصه ۶۰ ثانیه‌ای</h2></div>
            <span class="count">{{ brief.executive_snapshot.score }}</span>
          </div>
          <p class="panel-summary">{{ brief.executive_snapshot.summary_fa }}</p>
          <div class="meter risk-{{ brief.executive_snapshot.level }}"><span style="--bar: {{ brief.executive_snapshot.bar_width }}%"></span></div>
          <div class="risk-stack">
            {% for card in brief.executive_snapshot.risk_cards %}
            <article class="mini-card risk-{{ card.level }}">
              <div><b>{{ card.title }}</b><span>{{ card.metric }}</span></div>
              <p>{{ card.note_fa }}</p>
            </article>
            {% endfor %}
          </div>
        </section>

        <section id="priority" class="panel priority-panel" aria-label="مهم‌ترین سیگنال">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">اولویت امروز</span><h2>سیگنال اولویت‌دار</h2></div>
            <span class="count">Risk {{ brief.priority_alert.risk_score }}</span>
          </div>
          <article class="news-card lead-card">
            <h3><a href="{{ brief.priority_alert.url }}" rel="noopener noreferrer">{{ brief.priority_alert.title_fa }}</a></h3>
            <p>{{ brief.priority_alert.summary_fa }}</p>
            <div class="meta-row"><span>{{ brief.priority_alert.source }}</span>{% for tag in brief.priority_alert.tags %}<small>{{ tag }}</small>{% endfor %}</div>
          </article>
        </section>

        <section id="cves" class="panel" aria-label="آسیب‌پذیری‌های مهم">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">آسیب‌پذیری</span><h2>اولویت وصله</h2></div>
            <span class="count">{{ brief.cves | length }}</span>
          </div>
          <div class="compact-list">
            {% for cve in brief.cves %}{% if loop.index <= 6 %}
            <article class="row-card risk-{% if cve.severity == 'CRITICAL' %}high{% elif cve.severity == 'HIGH' %}medium{% else %}watch{% endif %}">
              <div class="row-main"><b>{{ cve.cve_id }}</b><span>{{ cve.title_fa }}</span></div>
              <p>{{ cve.summary_fa }}</p>
              <div class="meta-row"><small>{{ cve.severity }}</small>{% if cve.cvss is defined and cve.cvss != none %}<small>CVSS {{ cve.cvss }}</small>{% endif %}{% if cve.epss is defined and cve.epss != none %}<small>EPSS {{ (cve.epss * 100) | round }}%</small>{% endif %}{% if cve.epss_momentum == "rising" %}<small>EPSS رو به رشد</small>{% endif %}{% if cve.cisa_vulnrichment %}<small>CISA {{ cve.cisa_priority }}</small>{% endif %}{% if cve.kev %}<small>KEV</small>{% endif %}</div>
            </article>
            {% endif %}{% endfor %}
            {% if brief.cves | length == 0 %}<article class="empty-row">CVE مهمی برای این بازه دریافت نشد.</article>{% endif %}
          </div>
        </section>

        <section id="attack-pressure" class="panel" aria-label="فشار حمله">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">فشار حمله</span><h2>پورت‌های زیر فشار</h2></div>
            <span class="count">{{ brief.attack_pressure.level }}</span>
          </div>
          <p class="panel-summary">{{ brief.attack_pressure.summary_fa }}</p>
          <div class="tiny-bars">
            {% for port in brief.attack_pressure.top_ports %}{% if loop.index <= 8 %}
            <div class="risk-{{ port.risk }}"><span>{{ port.port }} · {{ port.service }}</span><i style="--bar: {{ port.bar_width }}%"></i><b>{{ port.pressure_score }}</b></div>
            {% endif %}{% endfor %}
          </div>
        </section>
      </aside>

      <section class="column column-news" aria-label="خبرهای فارسی">
        <section id="iran" class="panel news-panel">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">رادار ایران</span><h2>سیگنال‌های مرتبط با ایران</h2></div>
            <span class="count">{{ brief.iran_radar | length }}</span>
          </div>
          <div class="news-list">
            {% if brief.iran_radar | length == 0 %}<article class="empty-row">سیگنال مستقیم مرتبط با ایران در این اجرا دیده نشد.</article>{% endif %}
            {% for item in brief.iran_radar %}{% if loop.index <= 4 %}
            <article class="news-card">
              <h3><a href="{{ item.url }}" rel="noopener noreferrer">{{ item.title_fa }}</a></h3>
              <p>{{ item.summary_fa }}</p>
              <div class="meta-row"><span>{{ item.source }}</span><small>Risk {{ item.risk_score }}</small><small>{{ item.iran_context }}</small></div>
            </article>
            {% endif %}{% endfor %}
          </div>
        </section>

        <section id="global-news" class="panel news-panel dominant-panel">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">خبرهای جهانی</span><h2>خبرهای مهم جهانی</h2></div>
            <span class="count">{{ brief.global_news | length }}</span>
          </div>
          <div class="news-list dense-news">
            {% if brief.global_news | length == 0 %}<article class="empty-row">خبر جهانی مهمی وارد خروجی نشد.</article>{% endif %}
            {% for item in brief.global_news %}{% if loop.index <= 10 %}
            <article class="news-card risk-news-{{ item.category }}">
              <h3><a href="{{ item.url }}" rel="noopener noreferrer">{{ item.title_fa }}</a></h3>
              <p>{{ item.summary_fa }}</p>
              <div class="meta-row"><span>{{ item.source }}</span><small>Risk {{ item.risk_score }}</small><small>{{ item.category }}</small></div>
            </article>
            {% endif %}{% endfor %}
          </div>
        </section>
      </section>

      <aside class="column column-intel">
        <section id="ioc-radar" class="panel" aria-label="نشانگرهای تهدید">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">نشانگر تهدید</span><h2>نشانگرهای تازه</h2></div>
            <span class="count">{{ brief.ioc_radar.totals.total }}</span>
          </div>
          <p class="panel-summary">{{ brief.ioc_radar.summary_fa }}</p>
          <div class="tiny-bars split-two">
            {% for row in brief.ioc_radar.type_chart %}{% if loop.index <= 5 %}<div><span>{{ row.name }}</span><i style="--bar: {{ row.bar_width }}%"></i><b>{{ row.count }}</b></div>{% endif %}{% endfor %}
          </div>
          <div class="indicator-list">
            {% for ioc in brief.ioc_radar.urlhaus %}{% if loop.index <= 4 %}<code>{{ ioc.indicator_safe }}</code>{% endif %}{% endfor %}
            {% for ioc in brief.ioc_radar.threatfox %}{% if loop.index <= 3 %}<code>{{ ioc.indicator_safe }}</code>{% endif %}{% endfor %}
          </div>
        </section>

        <section id="infrastructure-radar" class="panel" aria-label="زیرساخت مشکوک">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">زیرساخت</span><h2>زیرساخت مشکوک</h2></div>
            <span class="count">{{ brief.infrastructure_radar.totals.hosts }}</span>
          </div>
          <p class="panel-summary">{{ brief.infrastructure_radar.summary_fa }}</p>
          <div class="compact-list">
            {% for host in brief.infrastructure_radar.hosts %}{% if loop.index <= 5 %}
            <article class="row-card risk-{{ host.risk }}">
              <div class="row-main"><b>{{ host.ip }}</b><span>{{ host.source }}</span></div>
              <div class="meter"><span style="--bar: {{ host.bar_width }}%"></span></div>
              <div class="meta-row"><small>{{ host.port_count }} port</small><small>{{ host.vuln_count }} vuln</small><small>{{ host.reason }}</small></div>
            </article>
            {% endif %}{% endfor %}
          </div>
        </section>

        <section id="supply-chain-radar" class="panel" aria-label="زنجیره تأمین">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">زنجیره تأمین</span><h2>ریسک اکوسیستم‌ها</h2></div>
            <span class="count">{{ brief.supply_chain_radar.totals.advisories }}</span>
          </div>
          <div class="tiny-bars">
            {% for row in brief.supply_chain_radar.severity_chart %}<div><span>{{ row.name }}</span><i style="--bar: {{ row.bar_width }}%"></i><b>{{ row.count }}</b></div>{% endfor %}
          </div>
          <div class="compact-list">
            {% for advisory in brief.supply_chain_radar.advisories %}{% if loop.index <= 4 %}
            <article class="row-card risk-{{ advisory.risk }}">
              <div class="row-main"><b>{{ advisory.package }}</b><span>{{ advisory.ecosystem }} · {{ advisory.severity }}</span></div>
              <p>{{ advisory.note_fa }}</p>
            </article>
            {% endif %}{% endfor %}
          </div>
        </section>

        <section id="ransomware-pulse" class="panel" aria-label="باج‌افزار">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">باج‌افزار</span><h2>claimهای عمومی</h2></div>
            <span class="count">{{ brief.ransomware_pulse.totals.victims }}</span>
          </div>
          <p class="panel-summary">{{ brief.ransomware_pulse.summary_fa }}</p>
          <div class="tiny-bars split-two">
            {% for row in brief.ransomware_pulse.group_chart %}{% if loop.index <= 5 %}<div class="risk-high"><span>{{ row.name }}</span><i style="--bar: {{ row.bar_width }}%"></i><b>{{ row.count }}</b></div>{% endif %}{% endfor %}
          </div>
          <div class="meta-row production-note"><small>{{ brief.ransomware_pulse.totals.recent_24h }} در ۲۴ ساعت</small><small>{{ brief.ransomware_pulse.totals.countries }} کشور</small><small>بدون پیوند افشا</small></div>
        </section>

        <section id="sources" class="panel source-panel" aria-label="سلامت منابع">
          <div class="panel-head compact-head">
            <div><span class="eyebrow">سلامت منابع</span><h2>سلامت منابع</h2></div>
            <span class="count">{{ brief.source_health.failed_rss_sources }} خطا</span>
          </div>
          <div class="health-grid">
            <div><span>RSS</span><b>{{ brief.source_health.rss_sources }}</b></div>
            <div><span>تله‌متری</span><b>{{ brief.source_health.intel_sources }}</b></div>
            <div><span>خطادار</span><b>{{ brief.source_health.failed_rss_sources }}</b></div>
          </div>
          {% if brief.source_health.rss_failures is defined and brief.source_health.rss_failures | length > 0 %}
          <div class="failure-mini">
            {% for failure in brief.source_health.rss_failures %}{% if loop.index <= 3 %}<span>{{ failure.name }}</span>{% endif %}{% endfor %}
          </div>
          {% else %}
          <p class="panel-summary">همه منابع خبری اصلی در این اجرا قابل استفاده بودند.</p>
          {% endif %}
        </section>
      </aside>
    </section>

    <footer>
      <p><b>SecPath Radar {{ brief.version }}</b> — نمای production، فشرده و فقط خواندنی برای آگاهی موقعیتی روزانه.</p>
    </footer>
  </main>
</body>
</html>
