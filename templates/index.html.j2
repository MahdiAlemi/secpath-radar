        </div>
        {% endif %}
        <div class="intel-kv-row threat-kv-row"><span><b>Family</b> {{ brief.malware_pulse.insights.top_family }}</span><span><b>Type</b> {{ brief.malware_pulse.insights.top_filetype }}</span><span><b>Display</b> metadata only</span></div>
        <div class="split-bars threat-bars">
          <div><span>Families</span>{% if brief.malware_pulse.named_family_chart %}{{ bars(brief.malware_pulse.named_family_chart, 3) }}{% else %}{{ bars(brief.malware_pulse.family_chart, 3) }}{% endif %}</div>
          <div><span>File types</span>{{ bars(brief.malware_pulse.filetype_chart, 3) }}</div>
        </div>
        <div class="meta"><span>{{ brief.malware_pulse.provider }}</span><span>hash-only</span></div>
      </section>

      <section id="ransomware-pulse" class="panel panel-intel-card panel-ransomware-card risk-{{ brief.ransomware_pulse.level|lower }}">
        <div class="panel-head">
          <div><span class="eyebrow">Ransomware</span><h2>Victim Claims</h2></div>
          <div class="panel-head-actions"><span class="chip">{{ brief.ransomware_pulse.totals.recent_7d }} in 7d</span><span class="chip chip-muted">{{ brief.ransomware_pulse.totals.groups }} groups</span></div>
        </div>
        <div class="intel-metric-row intel-metric-row-compact advisory-metric-row">
          <div><b>{{ brief.ransomware_pulse.totals.recent_24h }}</b><span>24h claims</span></div>
          <div><b>{{ brief.ransomware_pulse.totals.critical_sectors }}</b><span>Critical sector</span></div>
          <div><b>{{ brief.ransomware_pulse.totals.countries }}</b><span>Countries</span></div>
        </div>
        {% if brief.ransomware_pulse.spotlight %}
        <div class="advisory-spotlight ransomware-spotlight risk-{{ brief.ransomware_pulse.spotlight.risk }}">
          <div><span>Newest claim</span><b>{{ brief.ransomware_pulse.spotlight.victim_safe }}</b></div>
          <strong>{{ brief.ransomware_pulse.spotlight.group }}</strong>
        </div>
        {% endif %}
        <div class="intel-kv-row threat-kv-row"><span><b>Group</b> {{ brief.ransomware_pulse.insights.top_group }}</span><span><b>Country</b> {{ brief.ransomware_pulse.insights.top_country }}</span><span><b>Sector</b> {{ brief.ransomware_pulse.insights.top_sector }}</span></div>
        <div class="split-bars threat-bars">
          <div><span>Groups</span>{{ bars(brief.ransomware_pulse.group_chart, 3) }}</div>
          <div><span>Sectors</span>{{ bars(brief.ransomware_pulse.sector_chart, 3) }}</div>
        </div>
        <div class="meta"><span>{{ brief.ransomware_pulse.provider }}</span><span>public claims · passive</span></div>
      </section>

      <section class="panel panel-intel-card panel-meta-card panel-project-card">
        <div class="panel-head"><div><span class="eyebrow">Project</span><h2>About the Project</h2></div></div>
        <p class="note">SecPath Radar is a static, read-only dashboard for daily monitoring of the cyber threat landscape; no visitor data is collected.</p>
        <div class="meta"><span>Design &amp; Development: Mahdi Alemi</span><span>{{ brief.version }}</span></div>
      </section>

    </div>
  </section>

  <footer class="footer footer-redesign">
    <div class="footer-brand"><strong>SecPath Radar</strong><span>Static read-only cyber intelligence dashboard</span></div>
    <div class="footer-version">v2.0.0</div>
    <div class="footer-credit">Design &amp; Development: Mahdi Alemi</div>
  </footer>
</main>
</body>
</html>
