        <p class="poc-top-note">Public repository metadata published on {{ brief.poc_watch.date }} only. Links open the repository; no raw code, clone, or run commands are shown.</p>
        <div class="poc-top-list" aria-label="Fresh public PoC repository links">
          {% for repo in brief.poc_watch.repos %}
          <article class="poc-card risk-{{ repo.risk }}">
            <div class="poc-kind">{{ repo.repo_type_label }}</div>
            <div class="poc-main">
              <div class="poc-titleline">
                <a href="{{ repo.repo_url }}" rel="noopener noreferrer" target="_blank">{{ repo.repo_name }}</a>
                <span class="tag tag-poc">PoC</span>
                <span class="tag">{{ repo.language }}</span>
              </div>
              <div class="poc-author">
                <span>@{{ repo.author }}</span>
                <span>{{ repo.cve_id }}</span>
              </div>
