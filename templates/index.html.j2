<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ brief.site_title }} — {{ brief.date_en }}</title>
  <link rel="icon" type="image/svg+xml" href="assets/favicon.svg" />
  <link rel="stylesheet" href="assets/css/radar.css" />
  <script src="assets/js/radar.js" defer></script>
</head>
<body>
{% macro riskcls(score) %}{{ "high" if score >= 8 else ("medium" if score >= 5 else "low") }}{% endmacro %}
{% macro bars(rows, limit) %}
<div class="bars">
  {% for r in rows %}{% if loop.index <= limit %}
  <div class="bar-row" role="button" tabindex="0" data-chart-name="{{ r.name }}" data-chart-count="{{ r.count }}"><span class="bar-label">{{ r.name }}</span><span class="bar-track"><b style="width: {{ r.bar_width }}%"></b></span><span class="bar-count">{{ r.count }}</span></div>
  {% endif %}{% endfor %}
</div>
{% endmacro %}
{% macro news_card(item) %}
<article class="item risk-{{ riskcls(item.risk_score) }}{% if item.is_today == false %} is-older{% endif %}">
  <div class="item-head">
    <h3><a href="{{ item.url }}" rel="noopener noreferrer">{{ item.title }}</a></h3>
    <span class="score">{{ item.risk_score }}</span>
  </div>
  <p class="news-excerpt">{{ item.summary }}</p>
  <div class="meta">
    <span class="news-source">{{ item.source }}</span>
    <span class="news-time">{{ item.published_time_local }} Tehran &middot; {{ item.published_time_utc }}</span>
    <span class="news-date">{{ item.published_date_local }}</span>
    {% if item.is_new %}<span class="tag tag-new">New</span>{% endif %}
    {% for tag in item.tags %}{% if loop.index <= 2 %}<span class="tag">{{ tag }}</span>{% endif %}{% endfor %}
  </div>
</article>
{% endmacro %}
{% macro breaking_card(item) %}
<article class="item risk-{{ riskcls(item.risk_score) }}">
  <div class="item-head">
    <a href="{{ item.url }}" rel="noopener noreferrer" target="_blank">{{ item.title }}</a>
  </div>
  {% if item.summary %}<p class="news-excerpt">{{ item.summary }}</p>{% endif %}
  <div class="meta">
    <span class="breaking-source">{{ item.source }}</span>
    {% for tag in item.tags %}{% if loop.index <= 3 %}<span class="tag">{{ tag }}</span>{% endif %}{% endfor %}
  </div>
  <div class="meta">
    <span>{{ item.published_time_local }} Tehran · {{ item.published_time_utc }} · {{ item.published_date_local }}</span>
  </div>
</article>
{% endmacro %}
{% macro empty_pulse(id, title_en, provider, text) %}
<section id="{{ id }}" class="panel is-empty">
  <div class="panel-head">
    <div><span class="eyebrow">{{ title_en }}</span><h2>{{ title_en }}</h2></div>
    <span class="chip chip-idle">No data in this run</span>
  </div>
  <p class="empty-note">{{ text }}</p>
  <div class="meta"><span>{{ provider }}</span></div>
</section>
{% endmacro %}

<header class="topbar">
  <div class="brand"><img class="brand-logo" src="assets/logo.svg" alt="" width="34" height="34" /><strong>SecPath Radar</strong><span class="brand-sub">Passive Cyber Threat Monitoring</span></div>
  <div class="topbar-meta">
    <span class="live-chip" id="today-chip" data-today="{{ brief.date_en }}"><i class="live-dot"></i><span>Today &middot; {{ brief.date_en }}</span></span>
    <span class="chip chip-version">{{ brief.version }}</span>
  </div>
  <div class="topbar-actions">
    {% if brief.site_github %}<a class="ui-chip" href="{{ brief.site_github }}" rel="noopener noreferrer">GitHub</a>{% endif %}
    <a class="ui-chip" href="weekly.html">Weekly Digest</a>
    <span class="ui-chip" role="button" tabindex="0" data-ui-action="theme">Light/Dark</span>
  </div>
</header>

<nav class="anchor-nav" aria-label="Jump between clusters">
  <a href="#breaking-news" class="is-active">News</a>
  <a href="#top-signals">Overview</a>
  <a href="#cves">Vulnerabilities</a>
  <a href="#news">News</a>
  <a href="#writeups">Writeups</a>
  <a href="#sources">Sources</a>
</nav>

<main class="shell">

  <section class="kpi-strip" aria-label="Quick-decision metrics">
    <div class="kpi kpi-risk risk-{{ brief.risk_level|lower }}"><span>Risk Score</span><b>{{ brief.executive_snapshot.score }}</b><small>{{ brief.risk_level }}</small></div>
    <div class="kpi"><span>Critical CVEs</span><b>{{ brief.stats.critical_cves }}</b><small>of {{ brief.stats.cves }} CVE</small></div>
    <div class="kpi"><span>Exploitation</span><b>{{ brief.stats.kev }}</b><small>KEV &middot; {{ brief.stats.epss_rising }} EPSS&uarr; &middot; {{ brief.stats.poc_watch }} PoC</small></div>
    <div class="kpi"><span>Today's News</span><b>{{ brief.stats.daily_news }}</b><small>{{ brief.stats.breaking_news }} Breaking &middot; {{ brief.stats.writeups }} Research</small></div>
    <div class="kpi"><span>Active Threats</span><b>{{ brief.stats.iocs }}</b><small>IOC &middot; {{ brief.stats.botnet_c2 }} C2 &middot; {{ brief.stats.phishing_urls }} Phishing</small></div>
    <div class="kpi"><span>Nuclei Coverage</span><b>{{ brief.stats.nuclei_coverage_pct }}%</b><small>{{ brief.stats.nuclei_covered_cves }} CVE with template</small></div>
  </section>

  <section class="top-layout" aria-label="Dashboard overview">
    <section id="breaking-news" class="panel panel-breaking panel-breaking-col">
      <div class="panel-head"><div><span class="eyebrow">BREAKING</span><h2>Breaking News</h2></div><div class="breaking-head-actions"><button class="ai-btn" type="button" title="AI summary — coming soon" aria-label="AI summary coming soon">AI</button><span class="chip chip-risk">{{ brief.breaking_news|length }}</span></div></div>
      {% if brief.breaking_news %}
      <div class="breaking-scroll">
        {% for item in brief.breaking_news %}{{ breaking_card(item) }}{% endfor %}
      </div>
      {% else %}
      <p class="empty-note">No breaking news recorded in today's window.</p>
      {% endif %}
    </section>

    <section class="panel-weekly-right">
      <div class="wr-section">
        <div class="wr-head"><h3>Week at a Glance</h3><span class="chip">{{ brief.weekly.totals.days }}d</span></div>
        <div class="wr-stats">
          <div class="wr-stat"><b>{{ brief.weekly.totals.cves }}</b><span>CVEs</span></div>
          <div class="wr-stat"><b>{{ brief.weekly.totals.news }}</b><span>News</span></div>
          <div class="wr-stat"><b>{{ brief.weekly.totals.kev }}</b><span>KEV</span></div>
        </div>
        <p class="wr-text">{{ brief.weekly.summary }}</p>
      </div>

      <div class="wr-section">
        <div class="wr-head"><h3>Daily Breakdown</h3></div>
        {% for row in brief.weekly.daily_rows %}
        <div class="wr-row"><span class="wr-row-label">{{ row.label }}</span><span class="wr-row-val">{{ row.cves }}C &middot; {{ row.news }}N</span></div>
        {% endfor %}
      </div>

      <div class="wr-section">
        <div class="wr-head"><h3>Today</h3></div>
        <div class="wr-stats">
          <div class="wr-stat"><b class="c-red">{{ brief.stats.breaking_news }}</b><span>Breaking</span></div>
          <div class="wr-stat"><b class="c-amber">{{ brief.stats.epss_rising }}</b><span>EPSS&uarr;</span></div>
          <div class="wr-stat"><b>{{ brief.stats.poc_watch }}</b><span>PoC</span></div>
        </div>
      </div>

      <div class="wr-section">
        <div class="wr-head"><h3>60-Second</h3><span class="chip">{{ brief.executive_snapshot.score }}/100</span></div>
        {% for card in brief.executive_snapshot.risk_cards %}
        <div class="wr-row"><span class="wr-row-label">{{ card.title }}</span><span class="wr-row-val">{{ card.metric }}</span></div>
        {% endfor %}
      </div>

      <div class="wr-section">
        <div class="wr-head"><h3>Trend</h3><span class="chip">{{ brief.trend_pulse.totals.runs }}r</span></div>
        {% if brief.trend_pulse.ok %}
        <div class="trend-grid">
          {% for row in brief.trend_pulse.rows %}{% if loop.index <= 10 %}
          <div class="tg-row delta-{{ row.direction }}">
            <span class="tg-label">{{ row.label }}</span>
            <svg class="tg-spark" viewBox="0 0 60 16" preserveAspectRatio="none"><polyline points="{{ row.spark }}" vector-effect="non-scaling-stroke"/></svg>
            <span class="tg-count">{% if row.delta > 0 %}+{% endif %}{{ row.delta }}</span>
          </div>
          {% endif %}{% endfor %}
        </div>
        {% else %}
        <p class="wr-text">{{ brief.trend_pulse.summary }}</p>
        {% endif %}
      </div>
    </section>
  </section>

  <section id="top-signals" class="cluster" aria-label="Top signals">
    <div class="cluster-head"><span class="eyebrow">Top Signals</span><h2>Top Signals Today</h2></div>
    <div class="triage-row">
      {% for s in brief.top_signals %}{% if loop.index <= 5 %}
      <a class="triage-card risk-{{ s.level }}" href="{{ s.anchor }}">
        <div class="triage-top"><b>{{ s.title }}</b><span>{{ s.metric }}</span></div>
        <p>{{ s.note }}</p>
        <span class="bar-track"><b style="width: {{ s.bar_width }}%"></b></span>
      </a>
      {% endif %}{% endfor %}
    </div>
  </section>

  <section class="cluster cluster-news" aria-label="News &amp; Research">
    <div class="cluster-head"><span class="eyebrow">News &amp; Research</span><h2>News &amp; Research</h2></div>

      <section id="global-news" class="panel panel-news-global">
        <div class="panel-head"><div><span class="eyebrow">TODAY</span><h2>All News Today</h2></div><span class="chip">{{ brief.global_news|length }}</span></div>
        {% if brief.global_news %}
        <div class="news-grid">
          {% for item in brief.global_news %}{{ news_card(item) }}{% endfor %}
        </div>
        {% else %}
        <p class="empty-note">No news displayed in today's window.</p>
        {% endif %}
      </section>

      <section id="writeups-pulse" class="panel panel-wide">
        <div class="panel-head"><div><span class="eyebrow">Research</span><h2>Research</h2></div><span class="chip">{{ brief.writeups_pulse.totals.writeups }} from {{ brief.writeups_pulse.totals.sources }} sources</span></div>
        <p class="lede">{{ brief.writeups_pulse.summary }}</p>
        <div class="grid grid-2 grid-inner">
          {% for w in brief.writeups_pulse.writeups %}{% if loop.index <= 20 %}
          <article class="item risk-{{ w.risk }}">
            <div class="item-head"><h3><a href="{{ w.url }}" rel="noopener noreferrer">{{ w.title }}</a></h3><span class="tag">{{ w.kind }}</span></div>
            <p>{{ w.summary }}</p>
            <div class="meta"><span>{{ w.source }}</span><span>{{ w.freshness_label }}</span></div>
          </article>
          {% endif %}{% endfor %}
        </div>
      </section>
  </section>

  <section class="cluster" aria-label="Vulnerability &amp; Exploitation">
    <div class="cluster-head"><span class="eyebrow">Vulnerability &amp; Exploitation</span><h2>Vulnerability &amp; Exploitation</h2></div>
    <div class="grid grid-3">

      <section id="cves" class="panel panel-wide">
        <div class="panel-head"><div><span class="eyebrow">CVE</span><h2>Patch Priority</h2></div><span class="chip">{{ brief.stats.critical_cves }} critical &middot; {{ brief.stats.cves }} total</span></div>
        {% if brief.sev_strip %}
        <div class="sev-strip" role="img" aria-label="CVE severity distribution">{% for seg in brief.sev_strip %}<i class="sev-seg sev-{{ seg.sev }}" style="width: {{ seg.pct }}%" title="{{ seg.sev }}: {{ seg.count }}"></i>{% endfor %}</div>
        {% endif %}
        {% if brief.cves %}
        {% for cve in brief.cves %}{% if loop.index <= 30 %}
        <article class="item sev-{{ cve.severity|lower }}">
          <div class="item-head">
            <h3><a href="{{ cve.url }}" rel="noopener noreferrer">{{ cve.cve_id }}</a> &mdash; {{ cve.title }}</h3>
            <span class="sev-badge sev-{{ cve.severity|lower }}">{{ cve.severity }}</span>
          </div>
          <p>{{ cve.summary }}</p>
          <div class="meta">
            <span>CVSS {{ cve.cvss }}{% if cve.cvss_version %} &middot; v{{ cve.cvss_version }}{% endif %}</span>
            <span>EPSS {{ cve.epss }}{% if cve.epss_momentum == "rising" %} &uarr;{% endif %}</span>
            {% if cve.kev %}<span class="tag tag-risk">KEV{% if cve.kev_due_date %} &middot; due {{ cve.kev_due_date }}{% endif %}</span>{% endif %}{% if cve.kev_ransomware %}<span class="tag tag-risk">Ransomware</span>{% endif %}
            {% if cve.cisa_priority %}<span class="tag">CISA {{ cve.cisa_priority }}</span>{% endif %}
          </div>
          <p class="note">{{ cve.why_it_matters }}</p>
        </article>
        {% endif %}{% endfor %}
        {% else %}
        <p class="empty-note">No new CVEs recorded in the selected window this run.</p>
        {% endif %}
      </section>

      <section id="nuclei-coverage" class="panel">
        <div class="panel-head"><div><span class="eyebrow">Nuclei Coverage</span><h2>Template Coverage</h2></div><span class="chip">{{ brief.nuclei_coverage.totals.coverage_pct }}%</span></div>
        <p class="lede">{{ brief.nuclei_coverage.summary }}</p>
        {% for row in brief.nuclei_coverage.covered %}{% if loop.index <= 8 %}
        <div class="row">
          <div class="row-head"><b>{{ row.cve_id }}</b><span>{{ row.template_count }} template &middot; {{ row.protocol }}</span></div>
          <p class="note">{{ row.note }}</p>
        </div>
        {% endif %}{% endfor %}
        <div class="meta"><span>{{ brief.nuclei_coverage.provider }}</span><span>metadata only</span></div>
      </section>

      <section id="poc-watch" class="panel">
        <div class="panel-head"><div><span class="eyebrow">PoC Watch</span><h2>Fresh Public PoCs</h2></div><span class="chip">{{ brief.poc_watch.totals.repos }} repo &middot; {{ brief.poc_watch.totals.cves_with_poc }} CVE</span></div>
        <p class="lede">{{ brief.poc_watch.summary }}</p>
        {% for repo in brief.poc_watch.repos %}{% if loop.index <= 8 %}
        <div class="row risk-{{ repo.risk }}">
          <div class="row-head"><b>{{ repo.cve_id }}</b><span>{{ repo.language }} &middot; &#9733;{{ repo.stars }} &middot; {{ repo.age }}</span></div>
          <p class="note">{{ repo.note }}</p>
        </div>
        {% endif %}{% endfor %}
        <div class="meta"><span>{{ brief.poc_watch.provider }}</span><span>no code, metadata only</span></div>
      </section>

      {% if brief.supply_chain_radar.ok %}
      <section id="supply-chain-radar" class="panel">
        <div class="panel-head"><div><span class="eyebrow">Supply Chain</span><h2>Supply Chain</h2></div><span class="chip">{{ brief.supply_chain_radar.totals.advisories }} advisory</span></div>
        <p class="lede">{{ brief.supply_chain_radar.summary }}</p>
        {{ bars(brief.supply_chain_radar.ecosystem_chart, 5) }}
        <div class="meta"><span>{{ brief.supply_chain_radar.provider }}</span></div>
      </section>
      {% else %}
      {{ empty_pulse("supply-chain-radar", "Supply Chain", brief.supply_chain_radar.provider, brief.supply_chain_radar.summary) }}
      {% endif %}

      {% if brief.vendor_watchlist.ok %}
      <section id="vendor-watchlist" class="panel">
        <div class="panel-head"><div><span class="eyebrow">Vendor Watchlist</span><h2>Vendor Watchlist</h2></div><span class="chip">{{ brief.vendor_watchlist.totals.vendors }} vendors</span></div>
        <p class="lede">{{ brief.vendor_watchlist.summary }}</p>
        {{ bars(brief.vendor_watchlist.rows, 8) }}
        <div class="meta"><span>{{ brief.vendor_watchlist.provider }}</span></div>
      </section>
      {% else %}
      {{ empty_pulse("vendor-watchlist", "Vendor Watchlist", brief.vendor_watchlist.provider, brief.vendor_watchlist.summary) }}
      {% endif %}
    </div>
  </section>

  <section class="cluster" aria-label="Threat Telemetry">
    <div class="cluster-head"><span class="eyebrow">Threat Telemetry</span><h2>Threat Telemetry</h2></div>
    <div class="grid grid-3">

      {% if brief.ioc_radar.ok %}
      <section id="ioc-radar" class="panel">
        <div class="panel-head"><div><span class="eyebrow">IOC Radar</span><h2>Active Threats</h2></div><span class="chip">{{ brief.ioc_radar.totals.total }} IOC</span></div>
        <p class="lede">{{ brief.ioc_radar.summary }}</p>
        {{ bars(brief.ioc_radar.malware_chart, 5) }}
        <div class="meta"><span>{{ brief.ioc_radar.provider }}</span><span>defanged</span></div>
      </section>
      {% else %}
      {{ empty_pulse("ioc-radar", "IOC Radar", brief.ioc_radar.provider, brief.ioc_radar.summary) }}
      {% endif %}

      {% if brief.attack_pressure.ok %}
      <section id="attack-pressure" class="panel">
        <div class="panel-head"><div><span class="eyebrow">Attack Pressure</span><h2>Attack Pressure</h2></div><span class="chip">{{ brief.attack_pressure.level }}</span></div>
        <p class="lede">{{ brief.attack_pressure.summary }}</p>
        {% for p in brief.attack_pressure.top_ports %}{% if loop.index <= 8 %}
        <div class="row risk-{{ p.risk }}">
          <div class="row-head"><b>Port {{ p.port }} &middot; {{ p.service }}</b><span>{{ p.description }}</span></div>
          <p class="note">{{ p.note }}</p>
        </div>
        {% endif %}{% endfor %}
        <div class="meta"><span>{{ brief.attack_pressure.provider }}</span></div>
      </section>
      {% else %}
      {{ empty_pulse("attack-pressure", "Attack Pressure", brief.attack_pressure.provider, brief.attack_pressure.summary) }}
      {% endif %}

      {% if brief.attack_matrix.ok %}
      <section id="attack-matrix" class="panel">
        <div class="panel-head"><div><span class="eyebrow">ATT&amp;CK Map</span><h2>Attack Patterns</h2></div><span class="chip">{{ brief.attack_matrix.totals.techniques }} techniques</span></div>
        <p class="lede">{{ brief.attack_matrix.summary }}</p>
        {{ bars(brief.attack_matrix.rows, 8) }}
        <div class="meta"><span>{{ brief.attack_matrix.provider }}</span></div>
      </section>
      {% else %}
      {{ empty_pulse("attack-matrix", "ATT&CK Map", brief.attack_matrix.provider, brief.attack_matrix.summary) }}
      {% endif %}

      {% if brief.greynoise_context.ok %}
      <section id="greynoise-context" class="panel">
        <div class="panel-head"><div><span class="eyebrow">GreyNoise</span><h2>Infrastructure Context</h2></div><span class="chip">{{ brief.greynoise_context.totals.checked }} IP</span></div>
        <p class="lede">{{ brief.greynoise_context.summary }}</p>
        {% for c in brief.greynoise_context.contexts %}{% if loop.index <= 8 %}
        <div class="row risk-{{ c.risk }}">
          <div class="row-head"><b dir="ltr">{{ c.ip_safe }}</b><span>{{ c.classification }} &middot; {{ c.last_seen }}</span></div>
          <p class="note">{{ c.note }}</p>
        </div>
        {% endif %}{% endfor %}
        <div class="meta"><span>{{ brief.greynoise_context.provider }}</span><span>passive lookup</span></div>
      </section>
      {% else %}
      {{ empty_pulse("greynoise-context", "GreyNoise", brief.greynoise_context.provider, brief.greynoise_context.summary) }}
      {% endif %}

      {% if brief.botnet_c2_pulse.ok %}
      <section id="botnet-c2-pulse" class="panel">
        <div class="panel-head"><div><span class="eyebrow">Botnet C2</span><h2>C2 Infrastructure</h2></div><span class="chip">{{ brief.botnet_c2_pulse.totals.c2 }} C2</span></div>
        <p class="lede">{{ brief.botnet_c2_pulse.summary }}</p>
        {{ bars(brief.botnet_c2_pulse.family_chart, 5) }}
        <div class="meta"><span>{{ brief.botnet_c2_pulse.provider }}</span></div>
      </section>
      {% else %}
      {{ empty_pulse("botnet-c2-pulse", "Botnet C2", brief.botnet_c2_pulse.provider, brief.botnet_c2_pulse.summary) }}
      {% endif %}

      {% if brief.phishing_pulse.ok %}
      <section id="phishing-pulse" class="panel">
        <div class="panel-head"><div><span class="eyebrow">Phishing</span><h2>Phishing</h2></div><span class="chip">{{ brief.phishing_pulse.totals.urls }} URL</span></div>
        <p class="lede">{{ brief.phishing_pulse.summary }}</p>
        {{ bars(brief.phishing_pulse.brand_chart, 5) }}
        <div class="meta"><span>{{ brief.phishing_pulse.provider }}</span><span>defanged</span></div>
      </section>
      {% else %}
      {{ empty_pulse("phishing-pulse", "Phishing", brief.phishing_pulse.provider, brief.phishing_pulse.summary) }}
      {% endif %}

      {% if brief.malware_pulse.ok %}
      <section id="malware-pulse" class="panel">
        <div class="panel-head"><div><span class="eyebrow">Malware</span><h2>Malware Samples</h2></div><span class="chip">{{ brief.malware_pulse.totals.samples }} samples</span></div>
        <p class="lede">{{ brief.malware_pulse.summary }}</p>
        {{ bars(brief.malware_pulse.family_chart, 5) }}
        <div class="meta"><span>{{ brief.malware_pulse.provider }}</span><span>hash-only</span></div>
      </section>
      {% else %}
      {{ empty_pulse("malware-pulse", "Malware", brief.malware_pulse.provider, brief.malware_pulse.summary) }}
      {% endif %}

      {% if brief.drop_pulse.ok %}
      <section id="drop-pulse" class="panel">
        <div class="panel-head"><div><span class="eyebrow">DROP</span><h2>Hostile IP Ranges</h2></div><span class="chip">{{ brief.drop_pulse.totals.ranges }} ranges</span></div>
        <p class="lede">{{ brief.drop_pulse.summary }}</p>
        {{ bars(brief.drop_pulse.rir_chart, 5) }}
        <div class="meta"><span>{{ brief.drop_pulse.provider }}</span><span>defanged</span></div>
      </section>
      {% else %}
      {{ empty_pulse("drop-pulse", "DROP", brief.drop_pulse.provider, brief.drop_pulse.summary) }}
      {% endif %}

      {% if brief.csaf_pulse.ok %}
      <section id="csaf-pulse" class="panel">
        <div class="panel-head"><div><span class="eyebrow">CSAF</span><h2>Vendor Advisories</h2></div><span class="chip">{{ brief.csaf_pulse.totals.advisories }} advisory</span></div>
        <p class="lede">{{ brief.csaf_pulse.summary }}</p>
        {{ bars(brief.csaf_pulse.severity_chart, 5) }}
        <div class="meta"><span>{{ brief.csaf_pulse.provider }}</span></div>
      </section>
      {% else %}
      {{ empty_pulse("csaf-pulse", "CSAF", brief.csaf_pulse.provider, brief.csaf_pulse.summary) }}
      {% endif %}

      {% if brief.ics_ot_pulse.ok %}
      <section id="ics-ot-pulse" class="panel">
        <div class="panel-head"><div><span class="eyebrow">ICS / OT</span><h2>ICS / OT</h2></div><span class="chip">{{ brief.ics_ot_pulse.totals.advisories }} advisory</span></div>
        <p class="lede">{{ brief.ics_ot_pulse.summary }}</p>
        {{ bars(brief.ics_ot_pulse.vendor_chart, 5) }}
        <div class="meta"><span>{{ brief.ics_ot_pulse.provider }}</span></div>
      </section>
      {% else %}
      {{ empty_pulse("ics-ot-pulse", "ICS / OT", brief.ics_ot_pulse.provider, brief.ics_ot_pulse.summary) }}
      {% endif %}

      {% if brief.infrastructure_radar.ok %}
      <section id="infrastructure-radar" class="panel">
        <div class="panel-head"><div><span class="eyebrow">Infrastructure</span><h2>Suspicious Infrastructure</h2></div><span class="chip">{{ brief.infrastructure_radar.totals.hosts }} host</span></div>
        <p class="lede">{{ brief.infrastructure_radar.summary }}</p>
        {{ bars(brief.infrastructure_radar.port_chart, 5) }}
        <div class="meta"><span>{{ brief.infrastructure_radar.provider }}</span><span>passive</span></div>
      </section>
      {% else %}
      {{ empty_pulse("infrastructure-radar", "Infrastructure", brief.infrastructure_radar.provider, brief.infrastructure_radar.summary) }}
      {% endif %}

      {% if brief.ransomware_pulse.ok %}
      <section id="ransomware-pulse" class="panel">
        <div class="panel-head"><div><span class="eyebrow">Ransomware</span><h2>Ransomware</h2></div><span class="chip">{{ brief.ransomware_pulse.totals.recent_7d }} in 7 days</span></div>
        <p class="lede">{{ brief.ransomware_pulse.summary }}</p>
        {{ bars(brief.ransomware_pulse.group_chart, 5) }}
        <div class="meta"><span>{{ brief.ransomware_pulse.provider }}</span></div>
      </section>
      {% else %}
      {{ empty_pulse("ransomware-pulse", "Ransomware", brief.ransomware_pulse.provider, brief.ransomware_pulse.summary) }}
      {% endif %}
    </div>
  </section>

  <section id="sources" class="cluster" aria-label="About">
    <div class="cluster-head"><span class="eyebrow">About</span><h2>About</h2></div>
    <div class="grid grid-2">
      <section class="panel">
        <div class="panel-head"><div><span class="eyebrow">Data</span><h2>Data Feeds</h2></div></div>
        <p class="note">Automated collection from trusted security feeds, NVD, CISA KEV, EPSS, and public threat telemetry; all read-only with no active scanning.</p>
        <div class="meta"><span>{{ brief.source_health.rss_sources }} news feeds</span><span>{{ brief.source_health.intel_sources }} telemetry sources</span></div>
      </section>
      <section class="panel">
        <div class="panel-head"><div><span class="eyebrow">Project</span><h2>About the Project</h2></div></div>
        <p class="note">SecPath Radar is a static, read-only dashboard for daily monitoring of the cyber threat landscape; no visitor data is collected.</p>
        <div class="meta"><span>Design &amp; Development: Mahdi Alemi</span><span>{{ brief.version }}</span></div>
      </section>
    </div>
  </section>

  <footer class="footer">
    <span>SecPath Radar &middot; Passive Cyber Threat Monitoring</span>
    <span>Design &amp; Development: Mahdi Alemi</span>
    <span>{{ brief.version }}</span>
  </footer>
</main>
</body>
</html>
